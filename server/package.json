    "rollup-marketman-orders-daily": "tsx src/scripts/rollup-marketman-orders-daily.ts",
    "rollup-all-daily": "tsx src/scripts/rollup-all-daily.ts",
    "rollup-all": "tsx src/scripts/rollup-all-daily.ts",
    "rollup-square-orders-hourly": "tsx src/scripts/rollup-square-orders-hourly.ts",
    "rollup-square-order-periods": "tsx src/scripts/rollup-square-order-periods.ts",
