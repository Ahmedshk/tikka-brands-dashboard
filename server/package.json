    "test:business-date-keys": "tsx --test src/utils/businessDateKeysForUtcRange.util.test.ts",
    "test:homebase-ordered-buckets": "tsx --test src/utils/homebaseOrderedBuckets.util.test.ts",
    "test:business-day-utc-range": "tsx --test src/utils/businessDayUtcRange.util.test.ts",
    "test:hourly-rollup-read": "tsx --test src/utils/hourlyRollupRead.util.test.ts",
    "create-owner": "tsx src/scripts/create-owner.ts",
    "seed-roles": "tsx src/scripts/seed-roles.ts",
    "backfill-calendar-notification-jobs": "tsx src/scripts/backfill-calendar-notification-jobs.ts",
    "backfill-integration-cache-index-fields": "tsx src/scripts/backfill-integration-cache-index-fields.ts",
    "rollup-square-orders-daily": "tsx src/scripts/rollup-square-orders-daily.ts",
