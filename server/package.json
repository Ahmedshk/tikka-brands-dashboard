    "dotenv": "^17.2.3",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "googleapis": "^144.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.4",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.12",
    "react": "^19.2.3",
    "socket.io": "^4.8.3",
    "square": "^44.0.0",
    "twilio": "^5.13.0",
    "zod": "^4.3.5"
  },
