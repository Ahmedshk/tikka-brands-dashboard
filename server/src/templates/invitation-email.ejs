<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>You're invited to Tikka Brands Dashboard</title>
</head>
<body style="margin:0;padding:0;font-family:Onest,'Segoe UI',system-ui,-apple-system,sans-serif;background-color:#F5F5F5;color:#3B3B3B;">
  <div style="max-width:560px;margin:0 auto;padding:32px 24px;">
    <div style="background:#FFFFFF;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,0.06);overflow:hidden;">
      <div style="background:#5B6B79;color:#FFFFFF;padding:24px;text-align:center;">
        <% if (typeof logoUrl !== 'undefined' && logoUrl) { %>
        <img src="<%= logoUrl %>" alt="Tikka Brands" style="max-height:48px;height:48px;width:auto;display:block;margin:0 auto 12px auto;" />
        <% } %>
        <h1 style="margin:0;font-size:20px;font-weight:600;">Tikka Brands Dashboard</h1>
      </div>
      <div style="padding:28px 24px;">
        <p style="margin:0 0 16px;font-size:15px;line-height:1.5;">Hi <%= firstName %>.</p>
        <p style="margin:0 0 16px;font-size:15px;line-height:1.5;">You've been invited to join the Tikka Brands Dashboard. Click the link below to set your password and sign in. This link expires in 24 hours.</p>
        <p style="margin:8px 0 24px;font-size:15px;">
          <a href="<%= setPasswordUrl %>" style="display:inline-block;background:#5B6B79;color:#FFFFFF;text-decoration:none;padding:12px 24px;border-radius:8px;font-weight:600;font-size:14px;">Set your password</a>
        </p>
        <p style="font-size:13px;color:#5B6B79;margin:24px 0 0;padding-top:16px;border-top:1px solid #E5E7EB;">If the button doesn't work, copy and paste this link into your browser:<br /><a href="<%= setPasswordUrl %>" style="color:#5B6B79;"><%= setPasswordUrl %></a></p>
      </div>
    </div>
    <div style="text-align:center;padding:16px;font-size:12px;color:#9CA3AF;">Tikka Brands Dashboard – Invitation email</div>
  </div>
</body>
</html>
