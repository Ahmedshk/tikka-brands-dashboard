<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'Low inventory alert' %></title>
</head>
<body style="margin:0;padding:0;font-family:Onest,'Segoe UI',system-ui,-apple-system,sans-serif;background-color:#F5F5F5;color:#3B3B3B;">
  <div style="max-width:560px;margin:0 auto;padding:32px 24px;">
    <div style="background:#FFFFFF;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,0.06);overflow:hidden;">
      <div style="background:#5B6B79;color:#FFFFFF;padding:24px;text-align:center;">
        <% if (typeof logoUrl !== 'undefined' && logoUrl) { %>
        <img src="<%= logoUrl %>" alt="Tikka Brands" style="max-height:48px;height:48px;width:auto;display:block;margin:0 auto 12px auto;" />
        <% } %>
        <h1 style="margin:0;font-size:20px;font-weight:600;">Tikka Brands Dashboard</h1>
        <p style="margin:10px 0 0;font-size:13px;opacity:0.92;font-weight:500;">Alerts · Inventory</p>
      </div>
      <div style="padding:28px 24px;">
        <% if (typeof firstName !== 'undefined' && firstName) { %>
        <p style="margin:0 0 16px;font-size:15px;line-height:1.5;">Hi <%= firstName %>,</p>
        <% } %>

        <% var _calloutBg = typeof calloutBg !== 'undefined' ? calloutBg : '#FEF2F2'; %>
        <% var _calloutBorder = typeof calloutBorder !== 'undefined' ? calloutBorder : '#FECACA'; %>
        <% var _calloutText = typeof calloutText !== 'undefined' ? calloutText : '#991B1B'; %>
        <div style="background:<%= _calloutBg %>;border:1px solid <%= _calloutBorder %>;border-radius:10px;padding:16px 18px;margin:0 0 18px;border-left:4px solid <%= typeof accentColorHex !== 'undefined' && accentColorHex ? accentColorHex : '#DC2626' %>;">
          <p style="margin:0;font-size:15px;font-weight:600;color:<%= _calloutText %>;line-height:1.45;"><%= typeof calloutLine !== 'undefined' ? calloutLine : 'Low inventory detected.' %></p>
        </div>

        <% if (typeof locationName !== 'undefined' && locationName) { %>
        <p style="margin:0 0 10px;font-size:13px;color:#6B7280;"><span style="font-weight:600;color:#374151;">Location:</span> <%= locationName %></p>
        <% } %>

        <div style="border:1px solid #E5E7EB;border-radius:10px;padding:14px 16px;background:#F9FAFB;margin:0 0 18px;">
          <p style="margin:0 0 8px;font-size:14px;font-weight:700;color:#111827;"><%= typeof inventoryName !== 'undefined' && inventoryName ? inventoryName : 'Inventory item' %></p>
          <% if (typeof categoryName !== 'undefined' && categoryName) { %>
          <p style="margin:0 0 10px;font-size:13px;color:#6B7280;"><span style="font-weight:600;color:#374151;">Category:</span> <%= categoryName %></p>
          <% } %>

          <table style="width:100%;border-collapse:collapse;">
            <tr>
              <td style="padding:8px 0;font-size:13px;color:#6B7280;">Minimum on hand</td>
              <td style="padding:8px 0;font-size:13px;color:#111827;font-weight:700;text-align:right;">
                <%= typeof minOnHand !== 'undefined' ? minOnHand : '—' %><% if (typeof uomName !== 'undefined' && uomName) { %> <span style="font-weight:600;color:#6B7280;"><%= uomName %></span><% } %>
              </td>
            </tr>
            <tr style="border-top:1px solid #E5E7EB;">
              <td style="padding:8px 0;font-size:13px;color:#6B7280;">On hand</td>
              <td style="padding:8px 0;font-size:13px;color:#111827;font-weight:700;text-align:right;">
                <%= typeof onHand !== 'undefined' ? onHand : '—' %><% if (typeof uomName !== 'undefined' && uomName) { %> <span style="font-weight:600;color:#6B7280;"><%= uomName %></span><% } %>
              </td>
            </tr>
          </table>
        </div>

        <% if (typeof summaryMessage !== 'undefined' && summaryMessage) { %>
        <p style="margin:0 0 18px;font-size:15px;line-height:1.55;color:#374151;"><%= summaryMessage %></p>
        <% } %>

        <% if (typeof actionUrl !== 'undefined' && actionUrl) { %>
        <p style="margin:12px 0 0;font-size:15px;">
          <a href="<%= actionUrl %>" style="display:inline-block;background:#5B6B79;color:#FFFFFF;text-decoration:none;padding:12px 24px;border-radius:8px;font-weight:600;font-size:14px;"><%= typeof buttonText !== 'undefined' && buttonText ? buttonText : 'Open Command Center' %></a>
        </p>
        <p style="font-size:13px;color:#5B6B79;margin:22px 0 0;padding-top:16px;border-top:1px solid #E5E7EB;">If the button doesn't work, copy and paste this link into your browser:<br /><a href="<%= actionUrl %>" style="color:#5B6B79;word-break:break-all;"><%= actionUrl %></a></p>
        <% } %>
      </div>
    </div>
    <div style="text-align:center;padding:16px;font-size:12px;color:#9CA3AF;">Tikka Brands</div>
  </div>
</body>
</html>

