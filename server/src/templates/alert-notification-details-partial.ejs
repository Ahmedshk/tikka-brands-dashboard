<div style="margin:20px 0 0;padding:20px;background:#F9FAFB;border-radius:10px;border-left:4px solid <%= typeof accentColorHex !== 'undefined' && accentColorHex ? accentColorHex : '#5B6B79' %>;">
  <p style="margin:0 0 14px;font-size:12px;font-weight:600;color:#6B7280;text-transform:uppercase;letter-spacing:0.04em;">Alert details</p>
  <table role="presentation" style="width:100%;border-collapse:collapse;margin:0;">
    <% if (typeof categoryLabel !== 'undefined' && categoryLabel) { %>
    <tr>
      <td style="padding:6px 12px 6px 0;color:#6B7280;font-size:13px;vertical-align:top;white-space:nowrap;width:1%;">Category</td>
      <td style="padding:6px 0;font-size:14px;color:#374151;"><%= categoryLabel %></td>
    </tr>
    <% } %>
    <% if (typeof locationLine !== 'undefined' && locationLine) { %>
    <tr>
      <td style="padding:6px 12px 6px 0;color:#6B7280;font-size:13px;vertical-align:top;white-space:nowrap;">Location</td>
      <td style="padding:6px 0;font-size:14px;color:#374151;"><%= locationLine %></td>
    </tr>
    <% } %>
    <% if (typeof severityLabel !== 'undefined' && severityLabel) { %>
    <tr>
      <td style="padding:6px 12px 6px 0;color:#6B7280;font-size:13px;vertical-align:top;white-space:nowrap;">Severity</td>
      <td style="padding:6px 0;font-size:14px;color:#374151;"><%= severityLabel %></td>
    </tr>
    <% } %>
    <% if (typeof detailRows !== 'undefined' && detailRows && detailRows.length) { %>
    <% detailRows.forEach(function(row) { %>
    <tr>
      <td style="padding:6px 12px 6px 0;color:#6B7280;font-size:13px;vertical-align:top;white-space:nowrap;"><%= row.label %></td>
      <td style="padding:6px 0;font-size:14px;color:#374151;"><%= row.value %></td>
    </tr>
    <% }); %>
    <% } %>
  </table>
</div>
