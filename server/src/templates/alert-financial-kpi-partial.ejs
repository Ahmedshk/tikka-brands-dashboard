<div style="margin:20px 0 0;padding:0;">
  <p style="margin:0 0 12px;font-size:12px;font-weight:600;color:#6B7280;text-transform:uppercase;letter-spacing:0.04em;">Goal vs current</p>
  <table role="presentation" style="width:100%;border-collapse:collapse;margin:0;font-size:14px;border:1px solid #E5E7EB;border-radius:8px;overflow:hidden;">
    <tbody>
      <% financialKpiRows.forEach(function(row, idx) { %>
      <% var rowBg = (idx % 2 === 1) ? '#F9FAFB' : '#FFFFFF'; %>
      <tr style="background-color:<%= rowBg %>;">
        <td style="padding:10px 14px;color:#6B7280;font-size:13px;font-weight:600;border-bottom:1px solid #F3F4F6;width:45%;vertical-align:middle;"><%= row.label %></td>
        <td style="padding:10px 14px;color:#111827;font-weight:500;border-bottom:1px solid #F3F4F6;vertical-align:middle;text-align:right;"><%= row.value %></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>
