<div style="margin:20px 0 0;padding:20px;background:#F9FAFB;border-radius:10px;border-left:4px solid <%= typeof eventTypeColorHex !== 'undefined' && eventTypeColorHex ? eventTypeColorHex : '#5B6B79' %>;">
  <h2 style="margin:0 0 16px;font-size:18px;font-weight:600;color:#111827;line-height:1.3;"><%= typeof eventTitle !== 'undefined' ? eventTitle : '' %></h2>
  <table role="presentation" style="width:100%;border-collapse:collapse;margin:0;">
    <% if (typeof eventTypeName !== 'undefined' && eventTypeName) { %>
    <tr>
      <td style="padding:6px 12px 6px 0;color:#6B7280;font-size:13px;vertical-align:top;white-space:nowrap;width:1%;">Type</td>
      <td style="padding:6px 0;font-size:14px;color:#374151;"><%= eventTypeName %></td>
    </tr>
    <% } %>
    <% if (typeof locationLine !== 'undefined' && locationLine) { %>
    <tr>
      <td style="padding:6px 12px 6px 0;color:#6B7280;font-size:13px;vertical-align:top;white-space:nowrap;">Location</td>
      <td style="padding:6px 0;font-size:14px;color:#374151;"><%= locationLine %></td>
    </tr>
    <% } %>
    <% if (typeof scheduleRows !== 'undefined' && scheduleRows && scheduleRows.length) { %>
    <% scheduleRows.forEach(function(row) { %>
    <tr>
      <td style="padding:6px 12px 6px 0;color:#6B7280;font-size:13px;vertical-align:top;white-space:nowrap;"><%= row.label %></td>
      <td style="padding:6px 0;font-size:14px;color:#374151;"><%= row.value %></td>
    </tr>
    <% }); %>
    <% } %>
  </table>
  <% if (typeof hasDescription !== 'undefined' && hasDescription && typeof descriptionPlain !== 'undefined' && descriptionPlain) { %>
  <div style="margin-top:16px;padding-top:16px;border-top:1px solid #E5E7EB;">
    <p style="margin:0 0 6px;font-size:12px;font-weight:600;color:#6B7280;text-transform:uppercase;letter-spacing:0.04em;">Description</p>
    <p style="margin:0;font-size:14px;line-height:1.55;color:#374151;white-space:pre-wrap;"><%= descriptionPlain %></p>
  </div>
  <% } %>
</div>
