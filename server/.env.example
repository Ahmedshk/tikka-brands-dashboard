# Server environment variables. Copy to .env and fill in values.

NODE_ENV=development
PORT=5000
MONGODB_URI=
# Frontend app origin (CORS, invitation email login link and logo URL).
# Dev: e.g. http://localhost:5173  Production: e.g. https://dashboard.tikkaspice.com
CLIENT_URL=

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Per-location encrypted credentials (AES-256-GCM). Must be exactly 32 bytes as 64 hex characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=

# Optional: fallback Square/Homebase keys when a location has no stored credentials
# SQUARE_ACCESS_TOKEN=
# HOMEBASE_API_KEY=

# When false, Square aggregate reads use Mongo order scan only (skip rollup-first path).
# ROLLUP_READ_ENABLED=true

# Kitchen performance: parallel Square list queries across locations (default 4).
# KITCHEN_PERFORMANCE_LOCATION_CONCURRENCY=4

# MarketMan API (partner credentials from MarketMan Support; used to call GetToken).
# BuyerGuid is per location and stored as marketManBuyerGuid on each location.
MARKETMAN_API_KEY=
MARKETMAN_API_PASSWORD=
# POST /api/webhooks/marketman is not verified (HTTPS + valid JSON only). Restrict exposure at the edge if needed.

# Adobe Acrobat Sign (disciplinary e-sign). Enterprise integration key — see:
# https://helpx.adobe.com/sign/developer/integration-key.html
# ADOBE_SIGN_BASE_URI must be your account API host (https://api.*.adobesign.com), not secure.* / web host.
ADOBE_SIGN_INTEGRATION_KEY=
ADOBE_SIGN_BASE_URI=https://api.na4.adobesign.com
# Optional: when Adobe sends this value in X-AdobeSign-ClientId on webhooks, allow delivery (and send on REST if set).
# Also allowed without env: UB7E5BXCXY (webhooks created in Acrobat Sign admin UI).
# ADOBE_SIGN_CLIENT_ID=
# Public https base of this API (for registering agreement webhooks), e.g. https://your-api.example.com
# Webhook URL: {API_PUBLIC_URL}/api/webhooks/adobe-sign (GET = Adobe verification, POST = events).
# API_PUBLIC_URL=
# Square webhooks: optional global signature key (legacy / single-app). Prefer storing a key per location
# in Location Management (encrypted). Verification accepts this env key plus every location key that is set.
# Notification URL: {API_PUBLIC_URL}/api/webhooks/square
# SQUARE_WEBHOOK_SIGNATURE_KEY=
# Integration cache reads: default ON. Dashboard uses Mongo for Square orders/catalog/payments/team, Homebase timecards,
# and MarketMan snapshots/orders we sync — no live API for those reads. Set to 0 or false to use live APIs instead.
# EXTERNAL_DATA_CACHE_READ=
# Display name on generated PDFs (optional)
# COMPANY_NAME=Tikka Brands

# Google Calendar (single shared calendar; events carry locationId/eventTypeId in private extended props).
# Use a service account; share the target calendar with the service account email (Editor).
# Option A: path to the service account JSON file (standard GOOGLE_APPLICATION_CREDENTIALS).
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Option B: entire service account JSON on ONE line (required — .env cannot span multi-line JSON).
#   Wrap in single quotes so inner double quotes are preserved, e.g.:
# GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}'
# Minify the downloaded key with: node -p "JSON.stringify(JSON.parse(require('fs').readFileSync('key.json','utf8')))"
# Calendar ID from Google Calendar settings (often an email-like string).
GOOGLE_CALENDAR_ID=
# Optional: Workspace domain-wide delegation — user to impersonate (only if using delegation).
# GOOGLE_CALENDAR_IMPERSONATED_USER=

# Google Business Profile (reviews & ratings) — OAuth 2.0 web application credentials.
# Prerequisites: enable My Business Account Management, My Business Business Information, and
# Google My Business API in Google Cloud; configure consent screen with scope business.manage.
# Redirect URI (register in Google Cloud Console): {API_PUBLIC_URL}/api/google-business/oauth/callback
# GOOGLE_BUSINESS_OAUTH_CLIENT_ID=
# GOOGLE_BUSINESS_OAUTH_CLIENT_SECRET=
# Optional override; defaults to {API_PUBLIC_URL}/api/google-business/oauth/callback
# GOOGLE_BUSINESS_OAUTH_REDIRECT_URI=

# Agenda — calendar notification jobs: after startup, queue a one-shot job to rebuild calendar:notify-one
# jobs from the database (future events within the scheduling horizon).
# Leave empty or unset for normal API servers (recommended — resyncs jobs after deploy/restart).
# Set to 1 only to skip that automatic queue (rare). The npm script backfill-calendar-notification-jobs sets 1
# in-process when it calls initializeAgenda() so backfill does not run twice.
SKIP_CALENDAR_STARTUP_BACKFILL=
